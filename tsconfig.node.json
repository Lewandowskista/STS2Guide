{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "rootDir": "./electron",
    "outDir": "./dist-electron",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false,
    "esModuleInterop": true
  },
  "include": ["./electron"]
}
